import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np
from sklearn.model_selection import train_test_split
from sklearn.ensemble import RandomForestClassifier
from sklearn.tree import DecisionTreeClassifier
from sklearn.linear_model import LogisticRegression
from sklearn.metrics import (classification_report, confusion_matrix,
                             precision_recall_curve, auc)

print("Loading dataset...")
df = pd.read_csv("datasets/ROSIDS23.csv")


labels = df['Label']
df_numeric = df.select_dtypes(include=[np.number]).copy()

df_numeric.replace([np.inf, -np.inf], np.nan, inplace=True)
df_numeric.fillna(0, inplace=True)

y = (labels.astype(str).str.strip() != 'Benign').astype(int)
X = df_numeric

print(f"Total instances: {len(y)}")
print(f"Class distribution: Benign (0): {np.bincount(y)[0]}, Attack (1): {np.bincount(y)[1]}")

X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)

print("\nTraining Multiple Models for comparison...")
models = {
    "Random Forest": RandomForestClassifier(n_estimators=50, random_state=42),
    "Decision Tree": DecisionTreeClassifier(random_state=42),
    "Logistic Regression": LogisticRegression(max_iter=1000)
}

results_log = {}

for name, clf in models.items():
    print(f"Processing: {name}...")
    clf.fit(X_train, y_train)

preds = clf.predict(X_test)
    acc = clf.score(X_test, y_test)

    if clf.classes_.size > 1:
        probs = clf.predict_proba(X_test)[:, 1]
    else:
        probs = np.zeros(len(X_test))

    results_log[name] = {
        'accuracy': acc,
        'preds': preds,
        'probs': probs
    }

plt.figure(figsize=(10, 6))
names = list(results_log.keys())
accs = [results_log[n]['accuracy'] for n in names]
plt.bar(names, accs, color=['#2c5f85', '#4a90e2', '#7fb3d5'])
plt.ylim(min(accs) - 0.05, 1.0)
plt.title('Model Accuracy Comparison')
plt.ylabel('Accuracy Score')
plt.grid(axis='y', linestyle='--', alpha=0.5)
plt.show()

plt.figure(figsize=(10, 7))
for name in names:
    precision, recall, _ = precision_recall_curve(y_test, results_log[name]['probs'])
    pr_auc = auc(recall, precision)
    plt.plot(recall, precision, label=f'{name} (AP={pr_auc:.3f})')

plt.xlabel('Recall')
plt.ylabel('Precision')
plt.title('Precision-Recall Curves (Anomaly Detection)')
plt.legend(loc='lower left')
plt.grid(True, alpha=0.3)
plt.show()

fig, axes = plt.subplots(1, 3, figsize=(18, 5))
for i, name in enumerate(names):
    cm = confusion_matrix(y_test, results_log[name]['preds'])
    sns.heatmap(cm, annot=True, fmt='d', cmap='viridis', ax=axes[i], cbar=False)
    axes[i].set_title(f'{name} CM')
    axes[i].set_xlabel('Predicted')
    axes[i].set_ylabel('Actual')

plt.tight_layout()
plt.show()

print("\n--- PERFORMANCE SUMMARY ---")
for name in names:
    print(f"\n{name} Report:")
    print(classification_report(y_test, results_log[name]['preds']))
